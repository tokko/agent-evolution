# MiniMax cloud API credentials.
# Get yours at https://platform.minimax.io/
MINIMAX_API_KEY=REPLACE_ME

# Optional. Some MiniMax accounts require a GroupId as a query param.
# If set, it will be appended to the chat-completions URL. Leave empty otherwise.
MINIMAX_GROUP_ID=

# MiniMax model slug. Canonical: MiniMax-M2.7
MODEL=MiniMax-M2.7

# Append-only JSONL event log for the agent loop.
EVENT_LOG=./events.jsonl

# Allow the agent to rewrite its own source via edit_self.
# Set to false to run as a read-only observer.
SELF_MOD_ENABLED=true

# Hard cap on agent-loop iterations in one process lifetime.
# After an edit_self handoff, the counter resets in the new binary.
MAX_STEPS=25
