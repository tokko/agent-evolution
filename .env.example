# MiniMax cloud API credentials.
# Get yours at https://platform.minimax.io/
MINIMAX_API_KEY=REPLACE_ME

# Optional. Some MiniMax endpoints require a GroupId as a query param.
# If set, it will be appended to the chat-completions URL. Leave empty otherwise.
MINIMAX_GROUP_ID=

# MiniMax model slug. Canonical: MiniMax-M2.7
MODEL=MiniMax-M2.7

# HTTP server port for the kanban UI.
PORT=8080

# Where SQLite lives.
DB_PATH=./memory.db

# Where target repos get cloned.
WORKSPACE=./workspace

# Sandbox Docker image tag (built lazily on first run from sandbox.Dockerfile).
SANDBOX_IMAGE=agent-sandbox:latest

# Allow Genesis (and successor roles) to rewrite the daemon's own source.
SELF_MOD_ENABLED=true

# Hard cap on agent-loop iterations per task attempt.
MAX_STEPS=25
